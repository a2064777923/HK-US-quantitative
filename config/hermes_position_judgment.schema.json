{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a2064777923/HK-US-quantitative/hermes_position_judgment.schema.json",
  "title": "Hermes Position Review Judgment",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "packet_id",
    "review_id",
    "portfolio_id",
    "role",
    "symbol",
    "decision",
    "confidence",
    "reviewed_at",
    "advisory_only",
    "submits_orders",
    "supporting_factors",
    "opposing_factors",
    "risk_notes"
  ],
  "properties": {
    "schema": {
      "const": "hermes_position_judgment_v1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1,
      "description": "Copy from hermes_signal_review_packet_v1.packet_id."
    },
    "review_id": {
      "type": "string",
      "minLength": 1,
      "description": "Copy from position_review.items[].review_id."
    },
    "portfolio_id": {
      "type": "integer"
    },
    "role": {
      "type": "string",
      "enum": ["user", "simulation"]
    },
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["hold", "watch", "reduce", "exit", "trail_stop"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": "string"
    },
    "expiry_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "advisory_only": {
      "type": "boolean",
      "description": "Must be true; this judgment must not submit orders."
    },
    "submits_orders": {
      "type": "boolean",
      "description": "Must be false; position judgments are advisory review artifacts only."
    },
    "max_exit_quantity": {
      "type": "number",
      "minimum": 0,
      "description": "Optional advisory size cap for reduce or exit decisions."
    },
    "supporting_factors": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "opposing_factors": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "risk_notes": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "follow_up": {
      "type": "array",
      "items": {"type": "string"}
    },
    "market_context": {
      "type": "object"
    },
    "portfolio_context": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"decision": {"enum": ["reduce", "exit"]}}
      },
      "then": {
        "properties": {
          "max_exit_quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {"advisory_only": {"const": false}}
      },
      "then": false
    },
    {
      "if": {
        "properties": {"submits_orders": {"const": true}}
      },
      "then": false
    }
  ]
}
